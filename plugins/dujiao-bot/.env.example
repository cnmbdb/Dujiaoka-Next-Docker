# Dujiao Bot plugin environment

DUJIAO_BOT_IMAGE=ghcr.io/cnmbdb/dujioka-next-tgbot/dujiao-bot
DUJIAO_BOT_TAG=latest

# Telegram Bot identity
TELEGRAM_BOT_TOKEN=
TELEGRAM_BOT_USERNAME=
TELEGRAM_ADMIN_IDS=

# Public URLs
TELEGRAM_WEBHOOK_URL=
TELEGRAM_WEBHOOK_SECRET=
TELEGRAM_SHOP_URL=
TELEGRAM_SHOP_PRODUCT_PATH=/p/{slug}
TELEGRAM_CUSTOMER_SERVICE_URL=
TELEGRAM_REFERRAL_URL=
TELEGRAM_GIFT_URL=
TELEGRAM_MINI_APP_URL=
TELEGRAM_AUTH_DOC_URL=https://dujiao-next.com/services/telegram-bot

# Bot menu copy
TELEGRAM_BOT_HEADLINE=
TELEGRAM_BOT_SUBTITLE=Dujiao-Next 官方演示机器人
TELEGRAM_PROMO_LINE=早鸟价: 398U/终身
TELEGRAM_DEFAULT_LANGUAGE=zh-CN
TELEGRAM_WELCOME_ENABLED=true
TELEGRAM_WELCOME_MESSAGE=
TELEGRAM_HELP_ENABLED=true
TELEGRAM_HELP_TITLE=帮助中心

# Feature switches
ENABLE_AUTO_DELIVERY=false
ENABLE_CUSTOMER_SERVICE=false
ENABLE_NOTIFICATION=false
ENABLE_ORDER_TRACKING=false
ENABLE_BROADCAST=false

# Optional runtime tuning
LOG_LEVEL=info
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
SESSION_SECRET=
JWT_SECRET=
