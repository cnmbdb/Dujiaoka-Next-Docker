# Dujiao-Next lightweight deployment environment template
# This repository pulls remote images. Copy this file to .env and update values:
#   cp .env.example .env

# ---------------------------------------------------------------------------
# Image tags
# ---------------------------------------------------------------------------
TAG=latest

# ---------------------------------------------------------------------------
# Public access
# This production compose file does not publish host ports.
# Route public traffic with Cloudflare Tunnel to Docker services:
#   user  -> http://user:80
#   admin -> http://admin:80
#   api   -> http://api:3000
# ---------------------------------------------------------------------------
PUBLIC_USER_URL=https://user.example.com
PUBLIC_ADMIN_URL=https://admin.example.com
PUBLIC_API_URL=https://api.example.com

# ---------------------------------------------------------------------------
# Database
# ---------------------------------------------------------------------------
DB_NAME=dujiao_db
DB_USER=dujiao_user
DB_PASSWORD=dujiao_password

# ---------------------------------------------------------------------------
# Redis
# Docker internal Redis port is fixed at 6379.
# Leave REDIS_PASSWORD empty to disable Redis auth.
# ---------------------------------------------------------------------------
REDIS_PASSWORD=
REDIS_DB=0

# ---------------------------------------------------------------------------
# Initial admin account
# Change these before first production start.
# ---------------------------------------------------------------------------
DJ_DEFAULT_ADMIN_USERNAME=admin
DJ_DEFAULT_ADMIN_PASSWORD=admin123

# ---------------------------------------------------------------------------
# AppStore Expand
# ---------------------------------------------------------------------------
APPSTORE_IMAGE=ghcr.io/cnmbdb/dujioka-next-tgbot/appstore-expand
APPSTORE_TAG=latest
APPSTORE_TITLE=Dujiaoka AppStore Expand
APPSTORE_BUTTON_TEXT=扩展应用商店
APPSTORE_STATUS_TEXT=应用商店扩展开启
APPSTORE_FRONTEND_URL=https://ets.txsw.top
APPSTORE_FRONTEND_LOGIN_PATH=/login

# ---------------------------------------------------------------------------
# Dujiao Bot
# ---------------------------------------------------------------------------
DUJIAO_BOT_IMAGE=ghcr.io/cnmbdb/dujioka-next-tgbot/dujiao-bot
DUJIAO_BOT_TAG=latest

# ---------------------------------------------------------------------------
# Cloudflare Tunnel
# Set CLOUDFLARE_TUNNEL_ENABLED=true and COMPOSE_PROFILES=tunnel to make
# docker compose pull / up include the Cloudflare Tunnel service by default.
# ---------------------------------------------------------------------------
CLOUDFLARE_TUNNEL_ENABLED=false
# COMPOSE_PROFILES=tunnel
TUNNEL_TOKEN=
