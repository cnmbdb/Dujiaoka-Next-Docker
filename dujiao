#!/usr/bin/env bash
set -Eeuo pipefail

ROOT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
PLUGINS_DIR="${ROOT_DIR}/plugins"
PROJECT_NAME="${COMPOSE_PROJECT_NAME:-dujiao-next}"

die() {
  printf '错误: %s\n' "$*" >&2
  exit 1
}

plugin_dir() {
  local name="${1:-}"
  [[ "$name" =~ ^[a-z0-9][a-z0-9._-]*$ ]] || die "无效插件名: ${name}"
  printf '%s/%s\n' "$PLUGINS_DIR" "$name"
}

validate_plugin() {
  local dir="$1"
  [[ -d "$dir" ]] || die "插件目录不存在: ${dir}"
  [[ -f "$dir/plugin.json" ]] || die "缺少 plugin.json: ${dir}"
  [[ -f "$dir/docker-compose.yml" ]] || die "缺少 docker-compose.yml: ${dir}"
}

compose_args() {
  COMPOSE_ARGS=(
    docker compose
    --project-directory "$ROOT_DIR"
    --project-name "$PROJECT_NAME"
  )

  if [[ -f "$ROOT_DIR/.env" ]]; then
    COMPOSE_ARGS+=(--env-file "$ROOT_DIR/.env")
  fi
  COMPOSE_ARGS+=(-f "$ROOT_DIR/docker-compose.yml")

  local dir
  while IFS= read -r dir; do
    [[ "$(basename "$dir")" == 'appstore' || -f "$dir/.enabled" ]] || continue
    validate_plugin "$dir"
    if [[ -f "$dir/.env" ]]; then
      COMPOSE_ARGS+=(--env-file "$dir/.env")
    fi
    COMPOSE_ARGS+=(-f "$dir/docker-compose.yml")
  done < <(find "$PLUGINS_DIR" -mindepth 1 -maxdepth 1 -type d -print | LC_ALL=C sort)
}

run_compose() {
  compose_args
  "${COMPOSE_ARGS[@]}" "$@"
}

apply_stack() {
  run_compose config --quiet
  run_compose up -d --build --remove-orphans
}

list_plugins() {
  printf '%-24s %-10s %s\n' 'PLUGIN' 'STATE' 'SOURCE'
  local dir state source
  while IFS= read -r dir; do
    [[ -f "$dir/plugin.json" && -f "$dir/docker-compose.yml" ]] || continue
    state='disabled'
    if [[ "$(basename "$dir")" == 'appstore' ]]; then
      state='core'
    elif [[ -f "$dir/.enabled" ]]; then
      state='enabled'
    fi
    source='image'
    grep -Eq '^[[:space:]]*build:' "$dir/docker-compose.yml" && source='local-code'
    printf '%-24s %-10s %s\n' "$(basename "$dir")" "$state" "$source"
  done < <(find "$PLUGINS_DIR" -mindepth 1 -maxdepth 1 -type d -print | LC_ALL=C sort)
}

enable_plugin() {
  local name="${1:-}"
  local dir
  dir="$(plugin_dir "$name")"
  validate_plugin "$dir"

  if [[ "$name" == 'appstore' ]]; then
    printf 'App Store 是核心插件，正在重新应用。\n'
    apply_stack
    return
  fi

  if [[ ! -f "$dir/.env" && -f "$dir/.env.example" ]]; then
    cp "$dir/.env.example" "$dir/.env"
    printf '已创建配置: plugins/%s/.env\n' "$name"
  fi

  if [[ -f "$dir/.enabled" ]]; then
    printf '插件已启用，正在重新应用: %s\n' "$name"
    apply_stack
    return
  fi

  : > "$dir/.enabled"
  if ! apply_stack; then
    rm -f "$dir/.enabled"
    die "启用失败，已回滚插件状态: ${name}"
  fi
  printf '插件已启用: %s\n' "$name"
}

disable_plugin() {
  local name="${1:-}"
  local dir
  dir="$(plugin_dir "$name")"
  validate_plugin "$dir"

  [[ "$name" != 'appstore' ]] || die 'App Store 是核心插件，不能停用'

  if [[ ! -f "$dir/.enabled" ]]; then
    printf '插件本来就是停用状态: %s\n' "$name"
    return
  fi

  rm -f "$dir/.enabled"
  if ! apply_stack; then
    : > "$dir/.enabled"
    die "停用失败，已恢复插件状态: ${name}"
  fi
  printf '插件已停用并清理注入: %s\n' "$name"
}

usage() {
  cat <<'EOF'
用法:
  ./dujiao plugin list
  ./dujiao plugin enable <插件目录名>
  ./dujiao plugin disable <插件目录名>
  ./dujiao plugin apply
  ./dujiao plugin config
  ./dujiao plugin command <任意 docker compose 参数...>

直接把完整插件文件夹放进 plugins/，再执行 enable 即可构建、注入并启动。
EOF
}

[[ "${1:-}" == 'plugin' ]] || {
  usage
  exit 1
}

case "${2:-}" in
  list)
    list_plugins
    ;;
  enable)
    enable_plugin "${3:-}"
    ;;
  disable)
    disable_plugin "${3:-}"
    ;;
  apply)
    apply_stack
    ;;
  config)
    run_compose config
    ;;
  command)
    shift 2
    (($# > 0)) || die 'command 后缺少 docker compose 参数'
    run_compose "$@"
    ;;
  *)
    usage
    exit 1
    ;;
esac
